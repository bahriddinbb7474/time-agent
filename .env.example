### Telegram
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
ALLOWED_TELEGRAM_ID=123456789

### Runtime
TZ=Asia/Tashkent
LOG_TO_FILE=0
ENABLE_DEBUG_COMMANDS=false
ENABLE_GOOGLE_WRITES=false

### Google Calendar OAuth
# Client ID/secret are read from this Google OAuth credentials JSON file.
GCAL_CREDENTIALS_PATH=/run/secrets/google_credentials.json
GCAL_TOKEN_PATH=/app/data/google_token.json
GCAL_OAUTH_REDIRECT_URI=http://localhost:8085/oauth2callback
GCAL_SCOPES=https://www.googleapis.com/auth/calendar.events
GCAL_OAUTH_BIND_HOST=0.0.0.0
GCAL_OAUTH_PORT=8085
GCAL_OAUTH_TIMEOUT_SEC=300

### Fixed in current code
# SQLite DB path: ./data/app.db
# Aladhan prayer settings: Tashkent, Uzbekistan, method=3, school=1 (Hanafi)
